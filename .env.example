# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_channel_or_group_id

# ─── APIs ─────────────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# CRYPTOPANIC_API_KEY=your_cryptopanic_key # REMOVED:
LUNARCRUSH_API_KEY=your_lunarcrush_key

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=file:./cryptosense.db

# ─── Scanner Config ───────────────────────────────────────
# Minimum confidence score to trigger alert (0-100)
MIN_CONFIDENCE=65
# Max alerts per coin per X hours
COOLDOWN_HOURS=4
# Scanner interval in minutes
SCAN_INTERVAL_MINUTES=5
# Fundamental/sentiment refresh interval
FUNDAMENTAL_INTERVAL_MINUTES=15

# ─── Risk Management ─────────────────────────────────────
# Maximum SL % from entry
MAX_SL_PCT=8
# Minimum Risk/Reward ratio to send alert
MIN_RR_RATIO=2
